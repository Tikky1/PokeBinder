{
  "permissions": {
    "allow": [
      "Bash(curl:*)",
      "Bash(node -e \":*)",
      "Bash(node:*)",
      "Bash(python -c \":*)",
      "Bash(python3 -c \":*)",
      "Bash(python3 /tmp/write_script.py)",
      "Bash(python3 \"C:/tmp/write_script.py\")",
      "Bash(python \"C:/tmp/write_script.py\")",
      "Bash(where python3:*)",
      "Bash(python3 -c \"import json,sys; d=json.load\\(sys.stdin\\); print\\(json.dumps\\(d[0], indent=2\\)\\)\")",
      "Bash(wc:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(awk:*)",
      "Skill(update-config)",
      "Bash(powershell -Command \"Clear-Content 'C:\\\\Users\\\\efeka\\\\Desktop\\\\PokeBinder\\\\claude_log.txt'\")",
      "Bash(sed 's/\\\\.json$//')"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|Read|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$json = [Console]::In.ReadToEnd() | ConvertFrom-Json; $tool = $json.tool_name; $fp = if ($json.tool_input.file_path) { $json.tool_input.file_path } elseif ($json.tool_input.command) { $json.tool_input.command } else { '-' }; Add-Content -Path 'C:\\Users\\efeka\\Desktop\\PokeBinder\\claude_log.txt' -Value \"$(Get-Date -Format 'yyyy-MM-dd HH:mm:ss') | $tool | $fp\"",
            "shell": "powershell",
            "async": true
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$json = [Console]::In.ReadToEnd() | ConvertFrom-Json; $msg = $json.prompt; Add-Content -Path 'C:\\Users\\efeka\\Desktop\\PokeBinder\\claude_log.txt' -Value \"$(Get-Date -Format 'yyyy-MM-dd HH:mm:ss') | USER | $msg\"",
            "shell": "powershell",
            "async": true
          }
        ]
      }
    ]
  }
}
